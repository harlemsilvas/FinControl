{
  "name": "fincontrol",
  "version": "0.1.0",
  "private": true,
  "description": "ERP financeiro modular FinControl",
  "workspaces": [
    "apps/*"
  ],
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspace @fincontrol/api",
    "dev:api": "npm run dev --workspace @fincontrol/api",
    "dev:web": "npm run dev --workspace @fincontrol/web",
    "lint": "npm run lint --workspaces --if-present",
    "start": "npm run start --workspace @fincontrol/api",
    "preview:web": "npm run preview --workspace @fincontrol/web",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  }
}
