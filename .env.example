NODE_ENV=development
API_HOST=127.0.0.1
API_PORT=3000
LOG_LEVEL=info

DB_HOST=127.0.0.1
DB_PORT=5434
DB_NAME=fincontrol
DB_USER=fincontrol
DB_PASSWORD=change_me
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000

# Gere um segredo aleatorio com pelo menos 32 caracteres para cada ambiente.
AUTH_ACCESS_TOKEN_SECRET=change_me_to_a_random_secret_with_32_chars
AUTH_ACCESS_TOKEN_TTL_SECONDS=900
AUTH_REFRESH_TOKEN_TTL_DAYS=30
AUTH_ISSUER=fincontrol-api
AUTH_AUDIENCE=fincontrol

# Somente para o comando explicito `npm run bootstrap:master --workspace @fincontrol/api`.
BOOTSTRAP_MASTER_NAME=Operador Master
BOOTSTRAP_MASTER_EMAIL=master@example.com
BOOTSTRAP_MASTER_PASSWORD=123456
