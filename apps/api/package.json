{
  "name": "@fincontrol/api",
  "version": "0.1.0",
  "private": true,
  "description": "API do FinControl",
  "type": "module",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "bootstrap:master": "tsx --env-file=../../.env src/commands/bootstrap-master.ts",
    "dev": "tsx watch --env-file=../../.env src/server.ts",
    "lint": "eslint src test --max-warnings=0",
    "start": "node --env-file=../../.env dist/server.js",
    "test": "vitest run",
    "test:integration": "RUN_DATABASE_INTEGRATION=true node --env-file-if-exists=../../.env ../../node_modules/vitest/vitest.mjs run test/integration",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "fastify": "^5.6.0",
    "pg": "^8.16.0",
    "zod": "^4.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/node": "^22.18.0",
    "@types/pg": "^8.15.0",
    "eslint": "^9.36.0",
    "pino-pretty": "^13.1.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.44.0",
    "vitest": "^3.2.0"
  }
}
